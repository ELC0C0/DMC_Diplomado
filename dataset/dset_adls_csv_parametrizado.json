				},
				"folderPath": {
					"value": "@dataset().PrmDirectory",
					"type": "Expression"
				},
				"fileSystem": "landing"
			},
			"columnDelimiter": "|",
			"escapeChar": "\\",
			"firstRowAsHeader": true,
			"quoteChar": "\""
		},
		"schema": []
	},
	"type": "Microsoft.DataFactory/factories/datasets"
}