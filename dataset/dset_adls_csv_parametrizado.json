			"referenceName": "lnk_adls",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"PrmNomArchivo": {
				"type": "string"
			},
			"PrmDirectory": {
				"type": "string"
			}
		},
		"annotations": [],
		"type": "DelimitedText",
		"typeProperties": {
			"location": {
				"type": "AzureBlobFSLocation",
				"fileName": {
					"value": "@concat(dataset().PrmNomArchivo,'_',utcNow(),'.csv')\n",
